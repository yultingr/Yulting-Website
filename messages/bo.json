    "s5l1": "ང་ཚོས་ཉར་ཚགས་བྱས་པའི་ཁྱེད་ཀྱི་སྒེར་གྱི་ཆ་འཕྲིན་ལ་བལྟ་ཐུབ་པ།",
    "s5l2": "མི་འགྲིག་པའི་ཆ་འཕྲིན་བཅོས་སྒྲིག་བྱེད་འདུན་ཞུ་བ།",
    "s5l3": "ཁྱེད་ཀྱི་སྒེར་གྱི་ཆ་འཕྲིན་བསུབ་པའི་འདུན་ཞུ་བ།",
    "s5l4": "ཁྱེད་ཀྱི་སྒེར་གྱི་ཆ་འཕྲིན་བཀོལ་སྤྱོད་ལ་འགོག་རྩ་བྱེད་པ།",
    "s5p2": "ཐོབ་ཐང་འདི་དག་སྤྱོད་པར་གཤམ་གྱི་འབྲེལ་གཏུགས་ཆ་འཕྲིན་བེད་སྤྱོད་ཀྱིས་ང་ཚོར་འབྲེལ་བ་གནང་རོགས། ང་ཚོས་ཉིན་30ནང་ཁྱེད་ཀྱི་འདུན་ཞུར་ལན་འདེབས་བྱེད་ཐུབ།",
    "s6Title": "བདེ་འཇགས།",
    "s6p1": "ང་ཚོས་ཁྱེད་ཀྱི་སྒེར་གྱི་ཆ་འཕྲིན་ལ་དབང་མེད་ཀྱིས་ལྟ་བ་དང་། བསྒྱུར་བ། བརྡ་སྤྲོད། བསུབ་པ་སོགས་ལས་སྲུང་སྐྱོབ་ཀྱི་བྱ་ཐབས་ལེགས་པོ་ལེན་གྱི་ཡོད། འོན་ཀྱང་དྲ་རྒྱ་ཐོག་གི་བརྗེ་ལེན་ཐབས་ལམ་གང་ཡང་བརྒྱ་ཆ་བརྒྱ་བདེ་འཇགས་ཡིན་པའི་ཁས་ལེན་བྱེད་མི་ཐུབ།",
    "s7Title": "ཕྱི་རོལ་སྦྲེལ་མཐུད།",
    "s7p1": "ང་ཚོའི་དྲ་ཚིགས་སུ་ཕྱི་རོལ་དྲ་ཚིགས་ཀྱི་སྦྲེལ་མཐུད་ཡོད་སྲིད། ཕྱི་རོལ་དྲ་ཚིགས་ཀྱི་གསང་དོན་ལག་ལེན་དང་ནང་དོན་ལ་ང་ཚོས་འགན་འཁུར་མི་ལེན། ཁྱེད་ཀྱིས་བལྟ་བའི་ཕྱི་རོལ་དྲ་ཚིགས་ཀྱི་གསང་དོན་སྲིད་བྱུས་ཀློག་རོགས།",
    "s8Title": "སྲིད་བྱུས་འདིའི་བསྒྱུར་བ།",
    "s8p1": "ང་ཚོས་དུས་ནས་དུས་སུ་གསང་དོན་སྲིད་བྱུས་འདི་གསར་བསྒྱུར་བྱེད་སྲིད། བསྒྱུར་བ་གང་ཡང་ཤོག་ངོས་འདིར་གསར་བསྒྱུར་ཟླ་ཚེས་དང་བཅས་འཁོད་རྒྱུ། སྲིད་བྱུས་འདི་དུས་ནས་དུས་སུ་ཀློག་རོགས།",
    "s9Title": "ང་ཚོར་འབྲེལ་བ་གནང་།",
    "s9p1": "གསང་དོན་སྲིད་བྱུས་འདི་དང་ང་ཚོའི་གཞི་གྲངས་ལག་ལེན་སྐོར་དྲི་བ་ཡོད་ན། གཤམ་གསལ་ཐོག་ང་ཚོར་འབྲེལ་བ་གནང་རོགས།",
