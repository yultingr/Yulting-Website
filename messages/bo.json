    "metaTitle": "ངོ་སྤྲོད།",
    "metaDescription": "ཡུལ་སྟེང་རིན་པོ་ཆེའི་སྐོར། — དགའ་ལྡན་ཤར་རྩེ་གྲྭ་ཚང་གི་སློབ་དཔོན། ལོ་ཙཱ་བ། ནང་ཆོས་མཁས་པ།",
    "bio1": "ང་ནི་ལྷོ་ཕྱོགས་རྒྱ་གར་གྱི་དགའ་ལྡན་ཤར་རྩེ་གྲྭ་ཚང་དུ་གནས་པའི་བོད་ཀྱི་ནང་པའི་དགེ་སློང་ཞིག་ཡིན། ༡༩༩༤ ལོར་བལ་ཡུལ་དུ་སྐུ་འཁྲུངས་ཤིང་། སྤྲུལ་སྐུ་ཡང་སྲིད་དུ་ངོས་འཛིན་ཐོབ་པ་དང་། མི་ཚེའི་ཆ་ཤས་ཆེ་བ་དགོན་པའི་སློབ་གཉེར་ལ་བཏང་ཡོད། སློབ་དཔོན་རྣམས་ལས་སློབ་སྦྱོང་དང་། གྲོགས་པོ་སློབ་མ་རྣམས་དང་རྩོད་གླེང་། ཆོས་ཀྱི་གོ་རྟོགས་ཟབ་ཏུ་གཏོང་བར་འབད་བརྩོན་བྱེད་བཞིན་ཡོད།",
    "bio2": "དྲ་ཚིགས་འདི་ནི་ངས་སློབ་སྦྱོང་བྱས་པའི་ཅུང་ཟད་གཞན་ལ་མཉམ་སྤྱོད་བྱེད་པའི་འབད་བརྩོན་ཆུང་ཆུང་ཞིག་ཡིན་ཏེ། གཞན་ལ་ཕན་ཐོགས་ཡོང་བའི་རེ་བ་བྱེད་བཞིན་ཡོད།",
    "studiesTitle": "སློབ་གཉེར།",
    "studiesText1": "དགའ་ལྡན་ཤར་རྩེ་གྲྭ་ཚང་དུ་དགེ་ལུགས་པའི་སྲོལ་རྒྱུན་གྱི་སློབ་ཚན་སློབ་གཉེར་བྱེད་བཞིན་ཡོད། ཚད་མ། ཕར་ཕྱིན། དབུ་མ། མངོན་པ། འདུལ་བ་བཅས་ཀྱི་གཞུང་ཆེན་པོ་རྣམས་ཀྱི་སློབ་སྦྱོང་བྱེད་བཞིན་ཡོད། ད་ལྟ་དགེ་བཤེས་ལྷ་རམས་པའི་རྒྱུགས་སྤྲོད་ལ་གྲ་སྒྲིག་བྱེད་བཞིན་ཡོད། འདི་ནི་སློབ་གཉེར་གྱི་མཐར་ཐུག་གི་རིམ་པ་ཡིན།",
    "studiesText2": "སྲོལ་རྒྱུན་གྱི་སློབ་ཚན་དང་ཆབས་ཅིག དགོན་པའི་ཚན་རིག་སློབ་ཚན་ཡོངས་རྫོགས་ལོ་དྲུག་མཐར་ཕྱིན་ཡོད། སློབ་ཚན་འདིས་དངོས་ཁམས་རིག་པ། སྐྱེ་དངོས་རིག་པ། དབང་རྩའི་རིག་པ་བཅས་ནང་ཆོས་ཀྱི་གྲུབ་མཐའ་དང་མཉམ་དུ་ངོ་སྤྲོད་བྱས་ཡོད། ཉམས་མྱོང་འདིས་བསམ་གཏན་གྱི་སྲོལ་རྒྱུན་དང་དེང་རབས་ཚན་རིག་གཉིས་འཕྲད་སའི་ས་ཁུལ་མང་པོ་ངེས་ལ་མིག་ཁ་ཕྱེས་སོང་།",
    "teachingTitle": "སློབ་ཁྲིད་དང་ཡིག་སྒྱུར།",
    "teachingText1": "ལོ་ཤས་སྔོན་ནས་དགའ་ལྡན་ཤར་རྩེ་སློབ་གྲྭ་དུ་དབྱིན་བོད་ཡིག་སྒྱུར་གྱི་སློབ་ཁྲིད་གནང་བཞིན་ཡོད། གྲོགས་པོ་དགེ་འདུན་པ་རྣམས་ལ་འཛམ་གླིང་རྒྱ་ཆེ་བ་དང་འབྲེལ་བ་བྱེད་པའི་སྐད་ཡིག་གི་ནུས་པ་གོང་འཕེལ་གཏོང་བར་རོགས་རམ་བྱེད་བཞིན་ཡོད། དེའི་སྔོན་ལ། དགོན་པའི་སློབ་མ་རྣམས་ལ་ནང་ཆོས་ཀྱི་གྲུབ་མཐའ་དང་ཉམས་ལེན་གྱི་སློབ་ཁྲིད་གནང་བའི་གོ་སྐབས་ཐོབ།",
    "teachingText2": "ཡིག་སྒྱུར་གྱི་ལས་ཀ་ངའི་མི་ཚེའི་ནང་དོན་ལྡན་གྱི་ཆ་ཤས་ཤིག་ཏུ་གྱུར་ཡོད། ཨི་མོ་རི་བོད་ཀྱི་ཚན་རིག་ལས་གཞི་དང་། དགེ་འདུན་པའི་མཁས་པ་དང་ཚན་རིག་པ་རྣམས་མཉམ་དུ་འཛོམས་སའི་ཚོགས་འདུ་དང་ལས་བརྡར་སྣ་ཚོགས་སུ་ལོ་ཙཱ་བའི་ཕྱག་ལས་བསྒྲུབས་ཡོད། ལས་ཀ་འདི་ཧ་ཅང་དགའ་སྤྲོ་ཡོད་དེ། རིག་གཞུང་ཕུན་སུམ་ཚོགས་པ་གཉིས་ཀྱི་བར་ཟམ་པ་རྒྱག་པར་ཕན་ཐོགས་ཡོད།",
    "engagementsTitle": "དགོན་པའི་ཕྱི་རོལ་གྱི་ལས་རིམ།",
    "engagementsText1": "དགོན་པའི་ཕྱི་རོལ་གྱི་ཚོགས་འདུ་ལ་ཞུགས་པའི་བསོད་ནམས་ཐོབ་ཡོད། རྒྱ་བོད་མཁས་པའི་ཚོགས་འདུ་ཐེངས་གཉིས་པ་ཡང་ཚུད་ཡོད་ལ། དེར་བསམ་གཏན་གྱི་ཉམས་ལེན་དང་ནང་ཆོས་ཀྱི་སེམས་ཁམས་རིག་པའི་སྐོར་གཏམ་བཤད་པ་ཡིན། སིང་ག་པོར་དང་ས་གནས་གཞན་དུ་གདན་ཞུ་ཐོབ་སྐབས་ཆོས་བཤད་གནང་ཡོད།",
